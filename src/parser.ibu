struct Type {
	kind TypeKind,
	size i32,
	name *u8,

	// struct type
	members *MemberVec,

	// func type
	return_type *Type,
	params *TypeVec,
	is_variadic bool,

	// pointer type
	pointer_to *Type,

	is_unsigned bool,
	is_declaration bool,

	tok *Token,
}

func plural_or_singular(n i32) *u8 {
	if n == 1 {
		"";
	} else {
		"s";
	}
}

func plural_or_singular2(n i32) *u8 {
	if n == 1 {
		"y";
	} else {
		"ies";
	}
}

func func_call_args_length_error(exp_len i32, got_len i32, tok *Token, msg *u8) i32 {
	print_error_with_code(tok, msg);
	eprintf(
		"help: this function takes %d argument%s but %d argument%s were supplied\n",
		exp_len,
		plural_or_singular(exp_len),
		got_len,
		plural_or_singular(got_len)
	);
	exit(1);
}

func unkown_type_error(types *TypeVec, tok *Token, msg *u8) i32 {
	print_error_with_code(tok, msg);

	if types.len == 0 {
		exit(1);
	} else {
		eprintf("help: %d possibilit%s:", plural_or_singular2(types.len));
	}

	var idx i32 = 0;
	while idx < types.len {
		if idx+1 < types.len {
			eprintf(" `%s`,", types.ptr[idx].name);
		} else {
			eprintf(" `%s`", types.ptr[idx].name);
		}
		idx++;
	}

	eprintf("\n");

	exit(1);
}

func unkown_member_error(members *MemberVec, tok *Token, msg *u8) i32 {
	print_error_with_code(tok, msg);

	if members.len == 0 {
		exit(1);
	} else {
		eprintf("help: %d possibilit:", plural_or_singular2(members.len));
	}

	var idx i32 = 0;
	while idx < members.len {
		if idx+1 < members.len {
			eprintf(" `%s`,", members.ptr[idx].name);
		} else {
			eprintf(" `%s`", members.ptr[idx].name);
		}
		idx++;
	}

	eprintf("\n");

	exit(1);
}

#define ObjectKind	i32
#define OBJ_FUNC	0
#define OBJ_VAR		1

struct Object;
struct Node;

// NodeVec

