
#define NodeKind			i32
#define ND_ADD				0
#define ND_SUB				1
#define ND_MUL				2
#define ND_DIV				3
#define ND_MOD				4
#define ND_NOT				5
#define ND_NE				6
#define ND_EQ				7
#define ND_LE				8
#define ND_LT				9
#define ND_GE				10
#define ND_GT				11
#define ND_STR				12
#define ND_NUM				13
#define ND_VAR				14
#define ND_IF				15
#define ND_WHILE			16
#define ND_ASSIGN			17
#define ND_RETURN			18
#define ND_REF				19
#define ND_DEREF			20
#define ND_BLOCK			21
#define ND_EXPR_STMT		22
#define ND_GOTO				23
#define ND_LABEL			24
#define ND_FUNC_CALL		25
#define ND_LOGAND			26
#define ND_LOGOR			27
#define ND_MEMBER_ACCESS	28
#define ND_EMPTY            29
#define ND_SHL              30
#define ND_SHR              31

#define TypeKind	i32
#define TY_I64		0
#define TY_I32		1
#define TY_I16		2
#define TY_I8		3
#define TY_BOOL		4
#define TY_STRUCT	5
#define TY_FUNC		6
#define TY_PTR		7
#define TY_U64		8
#define TY_U32		9
#define TY_U16		10
#define TY_U8		11
#define TY_U0       12

struct StrVec {
	ptr **u8,
	len i32,
	cap i32,
}

func new_str_vec(cap i32) *StrVec {
	var vec *StrVec = alloc(typesize(StrVec));
	vec.ptr = alloc(typesize(*u8) * cap);
	if vec.ptr == nil {
		eprintf("alloc returned nil\n");
		exit(1);
	}
	vec.len = 0;
	vec.cap = cap;
	return vec;
}

func str_vec_realloc(vec *StrVec) i32 {
	var new_ptr *u8 = alloc(typesize(*u8) * vec.cap * 2);
	if new_ptr == nil {
		eprintf("alloc returned nil\n");
		exit(1);
	}
	memcpy(new_ptr, vec.ptr, (typesize(*u8) * vec.cap));
	vec.cap = vec.cap * 2;
	vec.ptr = new_ptr;
	return 0;
}

func vec_append_str(vec *StrVec, ty *u8) i32 {
	if vec.len >= vec.cap {
		str_vec_realloc(vec);
	}
	vec.ptr[vec.len] = ty;
	vec.len++;
	return 0;
}

