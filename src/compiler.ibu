
#include "src/std.ibu"

#define PROGRAM_MAX_SIZE 57000

// ----------------------------------
// Tokenizer
// ----------------------------------

struct Tokenizer {
	file_name *u8,
	col i32,
	line i32,
	program *u8,
}

// Tokens
#define TokenKind	i32
#define TK_NUM		0
#define TK_IDENT	1
#define TK_STR		2
#define TK_PUNCT	3
#define TK_EOF		4
#define TK_UNKOWN	5

struct Token;

struct Token {
	kind TokenKind,
	file_name *u8,
	line i32,
	col i32,
	lit *u8,
	str_val *u8,
	next *Token,
}

func new_tokenizer(file_name *u8, program *u8) *Tokenizer {
	var t *Tokenizer = alloc(typesize(Tokenizer));
	if t == nil {
		eprintf("alloc() returned nil\n");
		exit(1);
	}
	t.line = 1;
	t.col = 0;
	t.program = program;
	t.file_name = file_name;
	return t;
}

func strlen(str *u8) i32 {
	var start *u8 = str;
	while *str != nil {
		str++;
	}
	return str - start;
}

func print_error(tok *Token, msg *u8) i32 {
	eprintf("%s:%d:%d: error: %s\n", tok.file_name, tok.line, tok.col, msg);
	exit(1);
}

func is_three_c_punct(a *u8) bool {
	if a[0] == 46 && a[1] == 46 && a[2] == 46 {
		return true;
	}
	return false;
}

func is_two_c_punct(a *u8) bool {
	var puncts *u8 = "==<=>=!=++--||&&";
	var idx i32 = 0;
	while {
		if idx >= 15 {
			return false;
		}
		if a[0] == puncts[idx] && a[1] == puncts[idx+1] {
			return true;
		}
		idx = idx + 1;
	}
}

func tokenizer_next(t *Tokenizer) i32 {
	if *t.program == 10 { // new line
		t.line = t.line + 1;
		t.col = 0;
	} else {
		t.col = t.col + 1;
	}
	t.program++;
	return 0;
}

func new_token(t *Tokenizer, kind TokenKind, start *u8, len i32) *Token {
	var tok *Token = alloc(typesize(Token));
	if tok == nil {
		eprintf("alloc() returned nil\n");
		exit(1);
	}

	tok.line = t.line;
	tok.col = t.col;
	tok.file_name = t.file_name;
	tok.kind = kind;
	tok.lit = strndup(start, len);

	return tok;
}

func ispunct(c i8) bool {
	var punct_list *u8 = "+-<>;:{}=,()[].*#!%&/";

	while *punct_list != nil {
		if *punct_list == c {
			return true;
		}
		punct_list++;
	}

	return false;
}

func tokenize_number(t *Tokenizer) *Token {
	var digit_start *u8 = t.program;
	while isdigit(*t.program) {
		tokenizer_next(t);
	}
	return new_token(t, TK_NUM, digit_start, t.program-digit_start);
}

func skip_single_line_comment(t *Tokenizer) i32 {
	if (*t.program == 47) && (*(t.program+1) == 47) {
		tokenizer_next(t); // skip first `/`
		tokenizer_next(t); // skip second `/`
		while (*t.program != 10) && (*t.program != 0) {
			tokenizer_next(t);
		}
	}
	return 0;
}

func string_end(str *u8) *u8 {
	while *str != 34 {
		if *str == 10 || *str == 0 {
			eprintf("unclosed string literal\n");
			exit(1);
		}
		if *str == 92 { // back slash
			str++;
		}
		str++;
	}
	return str;
}

func read_escaped_char(t *Tokenizer) i8 {
	tokenizer_next(t);
	var c i8 = *t.program;
	if c == 110 {
		return 10;
	}
	if c == 116 {
		return 9;
	}
	return c;
}

func tokenize_string(t *Tokenizer) *Token {
	var string_start *u8 = t.program;

	tokenizer_next(t); // skip start `"`

	var end *u8 = string_end(t.program);
	var buf *u8 = alloc(end - t.program + 1);
	var len i32 = 0;

	while t.program < end {
		if *t.program == 92 {
			buf[len++] = read_escaped_char(t);
		} else {
			buf[len++] = *t.program;
		}

		tokenizer_next(t);
	}
	buf[len] = 0; // null terminator

	tokenizer_next(t); // skip end `"`

	var tok *Token = new_token(t, TK_STR, string_start, t.program - string_start);

	tok.str_val = buf;

	return tok;
}

func tokenize_ident(t *Tokenizer) *Token {
	var ident_start *u8 = t.program;
	while isalpha(*t.program) || isdigit(*t.program) || *t.program == 95 {
		tokenizer_next(t);
	}
	ident_end:
	return new_token(t, TK_IDENT, ident_start, t.program-ident_start);
}

func tokenize(t *Tokenizer) *Token {
	var head Token;
	var cur *Token = &head;

	while *t.program != nil {
		skip_single_line_comment(t);

		if isdigit(*t.program) {
			cur = cur.next = tokenize_number(t);
		} else if isalpha(*t.program) {
			cur = cur.next = tokenize_ident(t);
		} else if *t.program == 34 {
			cur = cur.next = tokenize_string(t);
		} else if is_two_c_punct(t.program) {
			cur = cur.next = new_token(t, TK_PUNCT, t.program, 2);
			t.program = t.program + 2;
		} else if is_three_c_punct(t.program) { // ...
			cur = cur.next = new_token(t, TK_PUNCT, t.program, 3);
			t.program = t.program + 3;
		} else if ispunct(*t.program) {
			cur = cur.next = new_token(t, TK_PUNCT, t.program, 1);
			tokenizer_next(t);
		} else if *t.program == 32 { // Space
			tokenizer_next(t);
		} else if *t.program == 10 { // New line
			tokenizer_next(t);
		} else if *t.program == 9 { // Tab
			tokenizer_next(t);
		} else {
			print_error(new_token(t, TK_UNKOWN, t.program, 1), "unkown character found");
		}
	}

	cur = cur.next = new_token(t, TK_EOF, t.program, 1);
	cur.lit = "EOF";

	return head.next;
}

func print_all_tokens(tok *Token) i32;
func print_all_tokens(tok *Token) i32 {
	if tok == nil {
		return 1;
	}

	printf("kind = %d\nlit = %s\n----------\n", tok.kind, tok.lit);

	if tok.next != nil {
		print_all_tokens(tok.next);
	}

	return 0;
}

// ----------------------------------
// Parser
// ----------------------------------

struct Member;
struct Type;

struct Member {
	ty *Type,
	name *u8,
	offset i32,
}

// MemberVec

struct MemberVec {
	ptr **Member,
	len i32,
	cap i32,
}

func new_member_vec(cap i32) *MemberVec {
	var vec *MemberVec = alloc(typesize(MemberVec));
	vec.ptr = alloc(typesize(*Member) * cap);
	if vec.ptr == nil {
		eprintf("alloc returned nil\n");
		exit(1);
	}
	vec.len = 0;
	vec.cap = cap;
	return vec;
}

func member_vec_realloc(vec *MemberVec) i32 {
	var new_ptr *u8 = alloc(typesize(*Member) * vec.cap * 2);
	if new_ptr == nil {
		eprintf("alloc returned nil\n");
		exit(1);
	}
	memcpy(new_ptr, vec.ptr, (typesize(*Member) * vec.cap));
	vec.cap = vec.cap * 2;
	vec.ptr = new_ptr;
	return 0;
}

func vec_append_member(vec *MemberVec, ty *Member) i32 {
	if vec.len >= vec.cap {
		member_vec_realloc(vec);
	}
	vec.ptr[vec.len] = ty;
	vec.len++;
	return 0;
}

// TypeVec

struct TypeVec {
	ptr **Type,
	len i32,
	cap i32,
}

func new_type_vec(cap i32) *TypeVec {
	var vec *TypeVec = alloc(typesize(TypeVec));
	vec.ptr = alloc(typesize(*Type) * cap);
	if vec.ptr == nil {
		eprintf("alloc returned nil\n");
		exit(1);
	}
	vec.len = 0;
	vec.cap = cap;
	return vec;
}

func type_vec_realloc(vec *TypeVec) i32 {
	var new_ptr *u8 = alloc(typesize(*Type) * vec.cap * 2);
	if new_ptr == nil {
		eprintf("alloc returned nil\n");
		exit(1);
	}
	memcpy(new_ptr, vec.ptr, (typesize(*Type) * vec.cap));
	vec.cap = vec.cap * 2;
	vec.ptr = new_ptr;
	return 0;
}

func vec_append_type(vec *TypeVec, ty *Type) i32 {
	if vec.len >= vec.cap {
		type_vec_realloc(vec);
	}
	vec.ptr[vec.len] = ty;
	vec.len++;
	return 0;
}

#define NodeKind			i32
#define ND_ADD				0
#define ND_SUB				1
#define ND_MUL				2
#define ND_DIV				3
#define ND_MOD				4
#define ND_NOT				5
#define ND_NE				6
#define ND_EQ				7
#define ND_LE				8
#define ND_LT				9
#define ND_GE				10
#define ND_GT				11
#define ND_STR				12
#define ND_NUM				13
#define ND_VAR				14
#define ND_IF				15
#define ND_WHILE			16
#define ND_ASSIGN			17
#define ND_RETURN			18
#define ND_REF				19
#define ND_DEREF			20
#define ND_BLOCK			21
#define ND_EXPR_STMT		22
#define ND_GOTO				23
#define ND_LABEL			24
#define ND_FUNC_CALL		25
#define ND_LOGAND			26
#define ND_LOGOR			27
#define ND_MEMBER_ACCESS	28

#define TypeKind	i32
#define TY_I64		0
#define TY_I32		1
#define TY_I16		2
#define TY_I8		3
#define TY_BOOL		4
#define TY_STRUCT	5
#define TY_FUNC		6
#define TY_PTR		7
#define TY_U64		8
#define TY_U32		9
#define TY_U16		10
#define TY_U8		11

struct Type {
	kind TypeKind,
	size i32,
	name *u8,

	// struct type
	members *MemberVec,

	// func type
	return_type *Type,
	params *TypeVec,

	// pointer type
	pointer_to *Type,

	is_unsigned bool,
	is_declaration bool,
}

#define ObjectKind	i32
#define OBJ_FUNC	0
#define OBJ_VAR		1

struct Object;
struct Node;

// NodeVec

