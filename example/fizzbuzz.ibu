
func main() i32 {
    var c i32;
    c = 1;
    while c <= 100 {
        if c % 15 == 0 {
            println("FizzBuzz");
        } else if c % 3 == 0 {
            println("Fizz");
        } else if c % 5 == 0 {
            println("Buzz");
        } else {
            iprintln(c);
        }
        c++;
    }
}

